---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Acento por página de caso: 'orange' (defecto) | 'green' | 'blue' */
  accent?: string;
  /** true en páginas de caso: el nav en reposo va en claro sobre hero oscuro */
  onDark?: boolean;
  /** Muestra el preloader (solo home) */
  preloader?: boolean;
}

const { title, description, accent = 'orange', onDark = false, preloader = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site);

// DUMMY: identidad del diseñador — sustituir por la real
const DESIGNER = 'Alex Serrano';
const LOGO = 'alxsrn';
// PLACEHOLDER: ID de Microsoft Clarity. Déjalo vacío para no inyectar el script.
const CLARITY_ID = '';
---

<!doctype html>
<html lang="en" data-accent={accent}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Tema: se resuelve antes de pintar para evitar flash (patrón del sitio origen) -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        document.documentElement.setAttribute(
          'data-theme',
          s ? s : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        );
      })();
    </script>

    <!-- Fuentes del sistema derivado: Syne 700/800 + Inter 300/400/600/800 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:ital,wght@0,300;0,400;0,600;0,700;0,800;1,300&display=swap"
    />

    <!-- Microsoft Clarity — rellena CLARITY_ID arriba para activarlo -->
    {
      CLARITY_ID && (
        <script
          is:inline
          define:vars={{ CLARITY_ID }}
        >{`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script",CLARITY_ID);`}</script>
      )
    }
  </head>
  <body class:list={[{ 'on-dark': onDark }]}>
    {
      preloader && (
        <div id="preloader" aria-hidden="true">
          <div class="pl-name">
            <span>{DESIGNER}</span>
          </div>
          <div class="pl-bar-wrap">
            <div class="pl-bar" />
          </div>
        </div>
      )
    }

    <!-- Cursor custom (estilo del sitio origen); oculto en táctil -->
    <div class="cursor" id="cursor" aria-hidden="true">
      <div class="cursor-arrow">
        <svg width="22" height="26" viewBox="0 0 22 26" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M2 2L20 12.5L11.5 14.5L7.5 24L2 2Z"
            fill="#EDEDE8"
            stroke="#0C0C0B"
            stroke-width="1.5"
            stroke-linejoin="round"
          ></path>
        </svg>
      </div>
    </div>

    <nav id="nav">
      <a class="nav-logo" href="/" aria-label={`${DESIGNER} — home`}>{LOGO}</a>
      <div class="nav-right">
        <div class="nav-links">
          <a href="/work">Work</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
        <button class="theme-btn" id="themeBtn" aria-label="Toggle colour theme">
          <span class="t-icon" aria-hidden="true">◐</span>
          <span id="themeLabel">Dark</span>
        </button>
      </div>
    </nav>

    <slot />

    <script>
      // ---- Nav: barra plana → cápsula flotante al hacer scroll ----
      const nav = document.getElementById('nav');
      const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 60);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // ---- Toggle de tema ----
      const btn = document.getElementById('themeBtn');
      const label = document.getElementById('themeLabel');
      const syncLabel = () => {
        const cur = document.documentElement.getAttribute('data-theme');
        if (label) label.textContent = cur === 'dark' ? 'Light' : 'Dark';
      };
      syncLabel();
      btn?.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme');
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        syncLabel();
      });

      // ---- Reveals: inferencia documentada (el origen usa GSAP) ----
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.rv, .tl').forEach((el) => io.observe(el));

      // ---- Cursor custom ----
      const cursor = document.getElementById('cursor');
      if (cursor && window.matchMedia('(pointer: fine)').matches) {
        let shown = false;
        window.addEventListener('mousemove', (e) => {
          if (!shown) {
            cursor.style.opacity = '1';
            shown = true;
          }
          cursor.style.transform = `translate(${e.clientX}px, ${e.clientY}px)`;
        });
        const hoverables = 'a, button, [role="button"]';
        document.addEventListener('mouseover', (e) => {
          const t = e.target as Element | null;
          document.body.classList.toggle('is-hovering', !!t?.closest(hoverables));
        });
      }

      // ---- Preloader (solo si existe en la página) ----
      const pl = document.getElementById('preloader');
      if (pl) {
        requestAnimationFrame(() => pl.classList.add('reveal'));
        setTimeout(() => pl.classList.add('done'), 1400);
      }
    </script>
  </body>
</html>
