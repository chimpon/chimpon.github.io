---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);

// DUMMY: bloque "Otros proyectos" — piezas menores sin caso propio
const others = [
  { title: 'Driver app quick-actions', type: 'Feature design · Fletta', year: '2024' },
  { title: 'Card activation flow rework', type: 'Conversion · Brizo Bank', year: '2022' },
  { title: 'Push-notification playbook', type: 'Lifecycle · Bocado', year: '2025' },
  { title: 'Accessibility audit & fixes', type: 'Platform · Brizo Bank', year: '2023' },
];
---

<Base
  title="Work — Alex Serrano"
  description="Selected product design work: retention and gamification, B2B information architecture, and a 0→1 design system. Dummy case studies."
>
  <main class="page-section page-top">
    <div class="s-header rv">
      <div>
        <p class="s-label">Case studies</p>
        <h1 class="s-title">Work</h1>
      </div>
      <span class="s-count">{String(work.length).padStart(2, '0')}</span>
    </div>

    <div class="projects">
      {work.map((entry, i) => <ProjectCard entry={entry} index={i} />)}
    </div>

    <!-- Otros proyectos: compuesto con el patrón de lista de experiencia -->
    <div class="other-list rv">
      <p class="detail-h">Other projects</p>
      <ul class="exp-list">
        {
          others.map((o) => (
            <li class="exp-item">
              <span class="ei-l">
                <span class="ei-co">{o.title}</span>
                <span class="ei-role">{o.type}</span>
              </span>
              <span class="ei-yr">{o.year}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </main>

  <footer class="cs-footer">
    <p>© {new Date().getFullYear()} Alex Serrano · Dummy portfolio content</p>
    <a class="cs-back-link" href="/">Back home</a>
  </footer>
</Base>
