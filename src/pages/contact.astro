---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBar from '../components/SectionBar.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="Contact"
  description={`Get in touch with ${site.name}, ${site.role} based in ${site.location}.`}
>
  <div class="container"><SectionBar label="Contact" /></div>

  <section class="container contact measure">
    <h1 class="contact__title">Let’s talk.</h1>
    <p class="contact__lede">
      The fastest way to reach me is email. I read everything and reply to anything concrete.
    </p>

    <p class="contact__email">
      <a href={`mailto:${site.email}`}>{site.email}</a> <!-- DUMMY -->
    </p>

    <div class="contact__actions">
      <Button href={site.links.linkedin} variant="outline">LinkedIn</Button>
      <Button href={site.links.cv} variant="outline">Download CV</Button>
    </div>

    <!-- Formulario opcional. GitHub Pages es estático: necesita un backend de
         formularios (p.ej. Formspree). Reemplaza la action por tu endpoint. -->
    <form class="form" action="https://formspree.io/f/FORM_ID_PLACEHOLDER" method="POST">
      <div class="form__field">
        <label class="label" for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="form__field">
        <label class="label" for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="form__field">
        <label class="label" for="message">Message</label>
        <textarea id="message" name="message" rows="5" required></textarea>
      </div>
      <Button type="submit" variant="primary">Send message</Button>
      <p class="form__note meta">Form needs a backend endpoint — placeholder action</p>
    </form>
  </section>
</BaseLayout>

<style>
  .contact { padding-top: var(--space-7); }
  .contact__title { font-size: var(--fs-h1); line-height: var(--lh-tight); }
  .contact__lede { font-size: var(--fs-lead); margin-top: var(--space-4); }
  .contact__email { font-family: var(--font-serif); font-size: var(--fs-h2); margin-top: var(--space-5); }
  .contact__email a { text-decoration: underline; text-underline-offset: 3px; }
  .contact__actions { display: flex; gap: var(--space-3); margin-top: var(--space-5); flex-wrap: wrap; }

  .form { margin-top: var(--space-8); border-top: var(--rule-heavy); padding-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .form__field { display: flex; flex-direction: column; gap: var(--space-2); }
  .form__field input, .form__field textarea {
    border: var(--border-field); border-radius: var(--radius-none);
    padding: var(--space-3); font-family: var(--font-ui); font-size: var(--fs-small);
    background: var(--color-paper);
  }
  .form__field input:focus-visible, .form__field textarea:focus-visible { outline: var(--focus-ring); outline-offset: 0; }
  .form__note { margin-top: var(--space-1); }
</style>
