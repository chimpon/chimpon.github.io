---
import Base from '../layouts/Base.astro';

// DUMMY: toda la página es contenido de relleno — sustituir por el real
const skills = [
  'Product strategy',
  'Interaction design',
  'Design systems',
  'User research',
  'Prototyping',
  'A/B testing',
  'Figma',
  'Design tokens',
  'Behavioural data',
  'Facilitation',
];
---

<Base
  title="About — Alex Serrano"
  description="Senior Product Designer with eight years across food tech, logistics and banking. Bio, experience and skills. Dummy content."
>
  <main class="page-section page-top">
    <div class="s-header rv">
      <div>
        <p class="s-label">About</p>
        <h1 class="s-title">About</h1>
      </div>
      <a class="cv-btn" href="#" aria-disabled="true">
        Download CV
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3">
          <path d="M6 2v6M3 6l3 3 3-3M2 10h8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="about-grid">
      <div class="about-bio rv">
        <p>
          I'm Alex — a product designer who believes the most interesting problems live
          <strong>after the signup screen</strong>. Acquisition gets the glory; retention pays the
          bills. <em>I design for the second week, not the first impression.</em>
        </p>
        <p>
          Over eight years I've worked across food tech, logistics and banking — usually as the
          only designer in the room, which taught me to make the case with data before making it
          with mockups.
        </p>
        <p>
          Away from the screen I mentor early-career designers and give the occasional talk about
          design systems and growth design. <!-- DUMMY -->
        </p>
      </div>

      <div class="about-side rv">
        <div>
          <p class="detail-h">Experience</p>
          <ul class="exp-list">
            <li class="exp-item">
              <span class="ei-l"><span class="ei-co">Bocado</span><span class="ei-role">Senior Product Designer — Growth</span></span>
              <span class="ei-yr">2024 –</span>
            </li>
            <li class="exp-item">
              <span class="ei-l"><span class="ei-co">Fletta</span><span class="ei-role">Senior Product Designer — Platform</span></span>
              <span class="ei-yr">2023 – 24</span>
            </li>
            <li class="exp-item">
              <span class="ei-l"><span class="ei-co">Brizo Bank</span><span class="ei-role">Product Designer — Design System</span></span>
              <span class="ei-yr">2021 – 23</span>
            </li>
            <li class="exp-item">
              <span class="ei-l"><span class="ei-co">Freelance</span><span class="ei-role">Product & web design</span></span>
              <span class="ei-yr">2017 – 21</span>
            </li>
          </ul>
        </div>

        <div>
          <p class="detail-h">Recognition</p>
          <ul class="awards-list">
            <li class="award-item">
              <span class="aw-l"><span class="aw-title">Best Fintech UX — shortlist</span><span class="aw-issuer">Dummy Awards</span></span>
              <span class="aw-yr">2023</span>
            </li>
            <li class="award-item">
              <span class="aw-l"><span class="aw-title">"Tokens before components"</span><span class="aw-issuer">Talk — Dummy Conf, Madrid</span></span>
              <span class="aw-yr">2024</span>
            </li>
            <li class="award-item">
              <span class="aw-l"><span class="aw-title">Design mentor</span><span class="aw-issuer">Dummy mentoring platform</span></span>
              <span class="aw-yr">2022 –</span>
            </li>
          </ul>
        </div>

        <div>
          <p class="detail-h">Skills & tools</p>
          <div class="skills-row">
            {skills.map((s) => <span class="skill-pill">{s}</span>)}
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="cs-footer">
    <p>© {new Date().getFullYear()} Alex Serrano · Dummy portfolio content</p>
    <a class="cs-back-link" href="/contact">Get in touch</a>
  </footer>
</Base>
