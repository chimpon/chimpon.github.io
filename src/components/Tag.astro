---
// Tag / categoría — derivado de C-DES (labels DESIGN/AFFAIRS sobre cards).
interface Props { href?: string; class?: string; }
const { href, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'span';
---
<Tag class:list={['tag', className]} {...href ? { href } : {}}><slot /></Tag>

<style>
  .tag {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
  }
  a.tag:hover { text-decoration: underline; text-underline-offset: 2px; } /* [INFERIDO] */
</style>
