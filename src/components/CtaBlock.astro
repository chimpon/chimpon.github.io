---
// CtaBlock — patrón del bloque newsletter de Monocle (C-RAD): fondo amarillo
// pálido, titular + texto + acción. Reusado para el CTA de contacto.
import Button from './Button.astro';
import { site } from '../data/site';
interface Props { heading?: string; text?: string; }
const {
  heading = 'Open to new Product Design roles',
  text = 'If you are hiring and the work above resonates, I would like to hear about it.',
} = Astro.props;
---
<section class="cta">
  <div class="container cta__inner">
    <div class="cta__copy">
      <h2 class="cta__heading">{heading}</h2>
      <p class="cta__text">{text}</p>
    </div>
    <div class="cta__actions">
      <Button href={`mailto:${site.email}`} variant="primary">Get in touch</Button>
      <Button href={site.links.cv} variant="outline">Download CV</Button>
    </div>
  </div>
</section>

<style>
  .cta { background: var(--color-accent-soft); margin-top: var(--space-9); }
  .cta__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-6); flex-wrap: wrap; padding-block: var(--space-8);
  }
  .cta__heading { font-family: var(--font-serif); font-size: var(--fs-h2); font-weight: var(--fw-regular); }
  .cta__text { color: var(--color-ink); max-width: 46ch; margin-top: var(--space-2); }
  .cta__actions { display: flex; gap: var(--space-3); flex-wrap: wrap; }
</style>
