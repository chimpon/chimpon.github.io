---
// Header — replica el lenguaje del masthead de Monocle (C-DES/C-MENU):
// topbar fina con CTA amarillo, wordmark centrado en serif display,
// flancos de texto pequeño, nav horizontal uppercase con hairline.
// Identidad propia del diseñador (NO la marca Monocle).
import { site } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="hdr">
  <!-- Topbar utilitaria -->
  <div class="topbar">
    <div class="container topbar__row">
      <span class="topbar__left label">Portfolio · 2026</span>
      <div class="topbar__right">
        <a class="label" href={site.links.cv}>CV</a>
        <a class="btn-mini" href="/contact/">Get in touch</a>
      </div>
    </div>
  </div>

  <!-- Masthead -->
  <div class="container masthead">
    <button class="menu-toggle ui" aria-expanded="false" aria-controls="mobile-menu">Menu</button>
    <p class="masthead__flank masthead__flank--left label">{site.role} · {site.location}</p>
    <a class="wordmark" href="/">{site.name}</a>
    <p class="masthead__flank masthead__flank--right label">{site.status}</p>
  </div>

  <!-- Nav primaria -->
  <nav class="primary" aria-label="Primary">
    <ul class="container primary__list" role="list">
      {site.nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['primary__link', { 'is-active': isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Menú móvil overlay (patrón C-MENU) -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <button class="mobile-menu__close ui" aria-label="Close menu">Close</button>
    <ul class="mobile-menu__list" role="list">
      {site.nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
  </div>
</header>

<style>
  /* Topbar */
  .topbar { border-bottom: var(--rule-hair); }
  .topbar__row { display: flex; align-items: center; justify-content: space-between; min-height: 38px; }
  .topbar__left { color: var(--color-muted); }
  .topbar__right { display: flex; align-items: center; gap: var(--space-4); }
  .topbar__right .label { color: var(--color-ink); text-decoration: none; }
  .btn-mini {
    background: var(--color-accent); color: var(--color-ink);
    font-family: var(--font-ui); font-size: var(--fs-button); font-weight: var(--fw-medium);
    letter-spacing: var(--ls-label); text-transform: uppercase; text-decoration: none;
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-none);
  }
  .btn-mini:hover { background: var(--accent-hover); text-decoration: none; } /* [INFERIDO] */

  /* Masthead */
  .masthead {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-6);
  }
  .wordmark {
    grid-column: 2;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-wordmark);
    letter-spacing: var(--ls-wordmark);
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    line-height: 1;
  }
  .wordmark:hover { text-decoration: none; }
  .masthead__flank { color: var(--color-muted); }
  .masthead__flank--left { justify-self: start; }
  .masthead__flank--right { grid-column: 3; justify-self: end; text-align: right; }
  .menu-toggle { display: none; }

  /* Nav primaria */
  .primary { border-top: var(--rule-hair); border-bottom: var(--rule-hair); }
  .primary__list {
    display: flex; justify-content: center; flex-wrap: wrap;
    gap: var(--space-6); list-style: none; margin: 0;
    padding-block: var(--space-3);
  }
  .primary__link {
    font-family: var(--font-ui); font-size: var(--fs-nav); font-weight: var(--fw-medium);
    letter-spacing: var(--ls-label); text-transform: uppercase; text-decoration: none;
  }
  .primary__link:hover { text-decoration: underline; text-underline-offset: 4px; } /* [INFERIDO] */
  .primary__link.is-active { text-decoration: underline; text-underline-offset: 4px; }

  /* Menú móvil */
  .mobile-menu {
    position: fixed; inset: 0; z-index: 50;
    background: var(--color-paper);
    padding: var(--space-6) var(--gutter);
    overflow-y: auto;
  }
  .mobile-menu__close { position: absolute; top: var(--space-5); right: var(--gutter); background: none; border: 0; cursor: pointer;
    font-size: var(--fs-nav); letter-spacing: var(--ls-label); text-transform: uppercase; }
  .mobile-menu__list { list-style: none; margin: var(--space-8) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-5); }
  .mobile-menu__list a {
    font-family: var(--font-display); font-size: var(--fs-h1); text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 720px) {
    .topbar__left, .masthead__flank { display: none; }
    .menu-toggle {
      display: inline-block; grid-column: 1; justify-self: start;
      background: none; border: 0; cursor: pointer;
      font-size: var(--fs-nav); letter-spacing: var(--ls-label); text-transform: uppercase;
    }
    .masthead { padding-block: var(--space-4); }
    .wordmark { font-size: var(--fs-h1); }
    .primary { display: none; }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const close = document.querySelector('.mobile-menu__close');
  const open = () => { menu?.removeAttribute('hidden'); toggle?.setAttribute('aria-expanded', 'true'); document.body.style.overflow = 'hidden'; };
  const shut = () => { menu?.setAttribute('hidden', ''); toggle?.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; };
  toggle?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') shut(); });
</script>
