---
// Placeholder DUMMY — no introduce estilo visual ajeno: usa color cream/ink
// de los tokens. Ratios realistas (16/9 cover, 4/3 ó 16/10 captura, 1/1 avatar).
// Trivial de reemplazar por una imagen real.
interface Props {
  ratio?: string;      // ej. '16/9', '4/3', '16/10', '1/1'
  label?: string;
  variant?: 'cream' | 'dark';
  class?: string;
}
const { ratio = '16/9', label = 'PLACEHOLDER', variant = 'cream', class: className = '' } = Astro.props;
---
<!-- DUMMY: reemplazar por imagen real -->
<div class:list={['ph', `ph--${variant}`, className]} style={`aspect-ratio:${ratio};`} role="img" aria-label={`Placeholder: ${label}`}>
  <span class="ph__label">{label}</span>
</div>

<style>
  .ph {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ph--cream { background-color: var(--color-cream); }
  .ph--dark  { background-color: var(--color-dark); }
  .ph__label {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .ph--dark .ph__label { color: var(--color-on-dark-muted); }
</style>
