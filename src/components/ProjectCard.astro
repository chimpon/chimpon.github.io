---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
  index: number;
}

const { entry, index } = Astro.props;
const d = entry.data;
const num = String(index + 1).padStart(2, '0');
const Tag = d.wip ? 'div' : 'a';
---

<Tag class:list={['pcard', 'rv', d.gradient, { 'pcard--wip': d.wip }]} href={d.wip ? undefined : `/work/${entry.id}/`}>
  <div class="pcard-inner">
    <div class="pcard-info">
      <div class="pcard-top">
        <span class="pnum">{num}</span>
        {
          d.wip && (
            <span class="wip-badge">
              <span class="wip-badge-dot" />
              Work in progress
            </span>
          )
        }
      </div>
      <div class="pcard-mid">
        <div>
          <p class="pcompany">{d.company} / {d.period}</p>
          <h3 class="pname">{d.title}</h3>
          <p class="pyear sr-only">{d.period}</p>
        </div>
        <div class="tags">
          {d.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </div>
      <div class="pmetrics">
        {
          d.metrics.map((m) => (
            <div class="pmetric">
              <span class="pm-val">{m.value}</span>
              <span class="pm-label">{m.label}</span>
            </div>
          ))
        }
      </div>
    </div>
    <div class="pcard-vis">
      <!-- DUMMY visual: gradiente + blobs del sistema (sustituir por imagen real) -->
      <div class="pcard-bg"></div>
      <div class="blob blob1"></div>
      <div class="blob blob2"></div>
      {
        !d.wip && (
          <div class="p-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 13L13 3M13 3H5M13 3V11" stroke="#fff" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        )
      }
    </div>
  </div>
</Tag>
