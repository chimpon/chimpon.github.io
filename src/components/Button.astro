---
// Button — derivado de C-SHOP (primario amarillo), C-DES (outline/negro).
// Esquinas vivas (--radius-none), uppercase sans, tracking de label.
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'dark';
  type?: 'button' | 'submit';
  class?: string;
}
const { href, variant = 'primary', type = 'button', class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';
---
<Tag
  class:list={['btn', `btn--${variant}`, className]}
  {...href ? { href } : { type }}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--fs-button);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    text-decoration: none;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-none);
    border: 0;
    cursor: pointer;
    line-height: 1;
  }
  /* Primario amarillo · C-SHOP/C-RAD */
  .btn--primary { background: var(--color-accent); color: var(--color-ink); }
  .btn--primary:hover { background: var(--accent-hover); text-decoration: none; } /* [INFERIDO] */

  /* Outline negro · C-DES (SHARE) — al hover se rellena, reutilizando la variante negra ya visible */
  .btn--outline { background: transparent; color: var(--color-ink); border: var(--border-button); }
  .btn--outline:hover { background: var(--color-ink); color: var(--color-on-dark); text-decoration: none; } /* [INFERIDO] */

  /* Fondo negro · C-DES (VIEW FULL PROGRAMME) */
  .btn--dark { background: var(--color-ink); color: var(--color-on-dark); }
  .btn--dark:hover { opacity: 0.85; text-decoration: none; } /* [INFERIDO] */
</style>
